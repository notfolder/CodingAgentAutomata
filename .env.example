# ==============================================================
# CodingAgentAutomata 環境変数サンプルファイル
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env
# ==============================================================

# --------------------------------------------------------------
# GitLab 接続設定
# --------------------------------------------------------------
# GitLabのPersonal Access Token（api スコープ必須）
GITLAB_PAT=your_gitlab_pat_here

# GitLab API のベースURL（例: https://gitlab.com）
GITLAB_API_URL=https://gitlab.com

# GitLab上のBotアカウントのユーザー名
GITLAB_BOT_NAME=coding-agent-bot

# タスク処理対象を識別するラベル名
GITLAB_BOT_LABEL=coding agent

# 処理中状態を示すラベル名
GITLAB_PROCESSING_LABEL=coding agent processing

# 処理完了状態を示すラベル名
GITLAB_DONE_LABEL=coding agent done

# --------------------------------------------------------------
# LiteLLM Proxy 設定
# --------------------------------------------------------------
# LiteLLM Proxy のベースURL（例: http://litellm:4000）
LITELLM_PROXY_URL=http://litellm:4000

# --------------------------------------------------------------
# データベース設定
# --------------------------------------------------------------
# PostgreSQL接続URL（docker-compose 内部のサービス名を使用）
DATABASE_URL=postgresql://user:password@postgresql:5432/db

# PostgreSQLユーザー名（docker-compose の postgresql サービスで使用）
POSTGRES_USER=user

# PostgreSQLパスワード（docker-compose の postgresql サービスで使用）
POSTGRES_PASSWORD=password

# PostgreSQLデータベース名（docker-compose の postgresql サービスで使用）
POSTGRES_DB=db

# --------------------------------------------------------------
# RabbitMQ 設定
# --------------------------------------------------------------
# RabbitMQ 接続URL（docker-compose 内部のサービス名を使用）
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# RabbitMQ デフォルトユーザー名
RABBITMQ_DEFAULT_USER=guest

# RabbitMQ デフォルトパスワード
RABBITMQ_DEFAULT_PASS=guest

# --------------------------------------------------------------
# 暗号化・認証設定
# --------------------------------------------------------------
# AES-256-GCM 暗号化鍵（base64エンコード、32バイト = 256bit の乱数を生成）
# 生成例: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your_base64_encoded_32byte_key_here

# JWT署名シークレットキー（十分に長いランダム文字列を使用してください）
JWT_SECRET_KEY=your_jwt_secret_key_here

# --------------------------------------------------------------
# Webhook 設定
# --------------------------------------------------------------
# GitLab Webhook の署名検証シークレット
GITLAB_WEBHOOK_SECRET=your_webhook_secret_here

# Webhook受信ポート（デフォルト: 8080）
WEBHOOK_PORT=8080

# --------------------------------------------------------------
# ポーリング設定
# --------------------------------------------------------------
# GitLab ポーリング間隔（秒）（デフォルト: 30）
POLLING_INTERVAL_SECONDS=30

# --------------------------------------------------------------
# 進捗報告設定
# --------------------------------------------------------------
# GitLab MR コメントへの進捗報告間隔（秒）（デフォルト: 60）
PROGRESS_REPORT_INTERVAL_SEC=60

# 進捗レポートに含めるログ末尾行数（デフォルト: 20）
PROGRESS_REPORT_SUMMARY_LINES=20

# 進捗ログバッファの最大行数（超えた場合は古い行を破棄）（デフォルト: 20000）
PROGRESS_REPORT_BUFFER_MAX_LINES=20000

# --------------------------------------------------------------
# CLI 実行設定
# --------------------------------------------------------------
# CLI 実行タイムアウト（秒）（デフォルト: 10800 = 3時間）
CLI_EXEC_TIMEOUT_SEC=10800

# --------------------------------------------------------------
# テスト環境専用設定
# --------------------------------------------------------------
# OpenAI APIキー（テスト環境のLiteLLM Proxy経由利用時）
OPENAI_API_KEY=

# Anthropic APIキー（テスト環境のLiteLLM Proxy経由利用時）
ANTHROPIC_API_KEY=

# LiteLLM Proxy マスターキー（テスト環境用）
LITELLM_MASTER_KEY=your_litellm_master_key_here
